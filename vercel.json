{
  "devCommand": "vite --port $PORT",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)",   "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" },
    {
      "source": "/((?!@vite|src|@react-refresh|node_modules).)*",
      "destination": "/index.html"
    }
  ]
}